rules_version = '2';

// Each signed-in user can read and write only their own subtree (/users/{uid}/…). No cross-user
// access. This is the real security boundary — the client paths use the uid, but the rules enforce
// it independently.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
